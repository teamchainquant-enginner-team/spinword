{
  "name": "spinword",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit tests/integration",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "simulate": "tsx scripts/simulate-rtp.ts",
    "words:validate": "tsx scripts/validate-word-pool.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset-sandbox": "tsx scripts/reset-sandbox.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "overrides": { "postcss": "^8.5.10" }
}
